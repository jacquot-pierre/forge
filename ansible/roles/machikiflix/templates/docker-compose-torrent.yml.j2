---
services:
  gluetun:
    image: qmcgaw/gluetun:v3.40.3
    container_name: gluetun
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    volumes:
      - {{ machikiflix_gluetun_folder }}:/gluetun
      - "/root/.step/certs/root_ca.crt:/usr/local/share/ca-certificates/machiki-ca.crt:ro"
    ports:
      - 39269:39269
      - 39269:39269/udp
    environment:
      - VPN_SERVICE_PROVIDER=airvpn
      - VPN_TYPE=wireguard
      - WIREGUARD_PRIVATE_KEY={{ machikiflix_wireguard_private_key }}
      - WIREGUARD_PRESHARED_KEY={{ machikiflix_wireguard_preshared_key }}
      - WIREGUARD_ADDRESSES={{ machikiflix_wireguard_addresses }}
      - SERVER_COUNTRIES=Netherlands
      - FIREWALL_VPN_INPUT_PORTS=39269
    networks:
      - proxy

  qbittorrent:
    image: lscr.io/linuxserver/qbittorrent:5.1.4
    container_name: "qbittorrent_docker"
    network_mode: "service:gluetun"
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Etc/UTC
      - WEBUI_PORT=8080
      - TORRENTING_PORT=39269
    volumes:
      - {{ machikiflix_torrent_folder }}/config:/config
      - {{ machikiflix_data }}/torrents:/data/torrents #optional
      - "/root/.step/certs/root_ca.crt:/usr/local/share/ca-certificates/machiki-ca.crt:ro"
      - "{{ machikiflix_arr_folder }}/update-certs.sh:/custom-cont-init.d/99-update-certs.sh:ro"
    restart: unless-stopped
    labels:
      traefik.enable: "true"
      traefik.http.routers.qbittorrent.service: qbittorrent
      traefik.http.routers.qbittorrent.rule: "Host(`qbittorrent.guerande.local.net`) || Host(`qbittorrent.machiki.fr`)"
      traefik.http.routers.qbittorrent.entrypoints: "web"
      traefik.http.services.qbittorrent.loadbalancer.server.port: 8080

networks:
  proxy:
    name: proxy
    external: true