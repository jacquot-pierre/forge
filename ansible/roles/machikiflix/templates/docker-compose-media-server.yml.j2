---
services:
  jellyfin:
    image: jellyfin/jellyfin:10.11
    container_name: "jellyfin_docker"
    restart: unless-stopped
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Etc/UTC
    volumes:
      - {{ machikiflix_media_server_folder }}/config:/config
      - {{ machikiflix_media_server_folder }}/cache:/cache
      - {{ machikiflix_data }}/media:/media # https://wiki.servarr.com/docker-guide#consistent-and-well-planned-paths
      - /etc/localtime:/etc/localtime:ro
      - "/root/.step/certs/root_ca.crt:/usr/local/share/ca-certificates/machiki-ca.crt:ro"
    networks:
      - proxy
    labels:
      traefik.enable: "true"
      traefik.http.routers.jellyfin.service: jellyfin
      traefik.http.routers.jellyfin.rule: "Host(`machikiflix.guerande.local.net`) || Host(`machikiflix.machiki.fr`)"
      traefik.http.routers.jellyfin.entrypoints: "web"
      traefik.http.services.jellyfin.loadbalancer.server.port: 8096

networks:
  proxy:
    name: proxy
    external: true
