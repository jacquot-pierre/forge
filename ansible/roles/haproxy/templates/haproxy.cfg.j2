global
    log /dev/log    local0
    log /dev/log    local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

    # Default SSL material locations
	ca-base /etc/ssl/certs
	crt-base /etc/ssl/private

	# See: https://ssl-config.mozilla.org/#server=haproxy&server-version=2.0.3&config=intermediate
    ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384
    ssl-default-bind-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256
    ssl-default-bind-options ssl-min-ver TLSv1.2 no-tls-tickets


defaults
    log     global
    mode    http
    option  httplog
    # Extended logging for SSL handshake debugging across all proxies
    log-format "%ci:%cp [%tr] %ft %b/%s %TR/%Tw/%Tc/%Tr/%Ta %ST %B %CC %CS %tsc %ac/%fc/%bc/%sc/%rc %sq/%bq %hr %hs %{+Q}r sni=\"%[ssl_fc_sni]\" ssl_v=\"%[ssl_fc_protocol]\" ssl_c=\"%[ssl_fc_cipher]\" ssl_err=\"%[ssl_fc_err]\" ssl_err_str=\"%[ssl_fc_err_str]\""
    error-log-format "%ci:%cp [%tr] %ft %b/%s ERROR_EARLY sni=\"%[ssl_fc_sni]\" ssl_err_code=\"%[ssl_fc_err]\" ssl_err_str=\"%[ssl_fc_err_str]\""
    option  dontlognull
    option  forwardfor
    timeout connect 5000
    timeout client  50000
    timeout server  50000
    errorfile 400 /etc/haproxy/errors/400.http
    errorfile 403 /etc/haproxy/errors/403.http
    errorfile 408 /etc/haproxy/errors/408.http
    errorfile 500 /etc/haproxy/errors/500.http
    errorfile 502 /etc/haproxy/errors/502.http
    errorfile 503 /etc/haproxy/errors/503.http
    errorfile 504 /etc/haproxy/errors/504.http

frontend http-in
    bind *:80
    http-request redirect scheme https code 301 unless { ssl_fc }

frontend https-in
    bind *:444 ssl crt {{ haproxy_cert_path }}
    
    # Add security headers
    http-response set-header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    http-response set-header X-Frame-Options "SAMEORIGIN"
    http-response set-header X-Content-Type-Options "nosniff"
    http-request add-header X-Forwarded-Proto https

    # Route to proxmox if path starts with /proxmox
    acl is_proxmox path_beg /proxmox
    use_backend proxmox_backend if is_proxmox

    # Route to machikiflix stack
    acl is_machikiflix_stack ssl_fc_sni -i machikiflix.guerande.local.net
    acl is_machikiflix_stack ssl_fc_sni -i sonarr.guerande.local.net
    acl is_machikiflix_stack ssl_fc_sni -i radarr.guerande.local.net
    acl is_machikiflix_stack ssl_fc_sni -i prowlarr.guerande.local.net
    acl is_machikiflix_stack ssl_fc_sni -i bazarr.guerande.local.net
    acl is_machikiflix_stack ssl_fc_sni -i qbittorrent.guerande.local.net
    acl is_machikiflix_stack ssl_fc_sni -i traefik.guerande.local.net
    acl is_machikiflix_stack ssl_fc_sni -i pinchflat.guerande.local.net
    use_backend machikiflix_backend if is_machikiflix_stack

frontend https-in-machikiflix
    bind *:443 ssl crt /etc/haproxy/certs/wildcard.machiki.fr.pem
    
    # Reject connections outside local network
    acl is_local_network src 192.168.0.0/16 172.20.0.0/24
    http-request deny if !is_local_network

    # Add security headers
    http-response set-header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    http-response set-header X-Frame-Options "SAMEORIGIN"
    http-response set-header X-Content-Type-Options "nosniff"
    http-request add-header X-Forwarded-Proto https

    acl is_machikiflix_stack ssl_fc_sni -i machikiflix.machiki.fr
    acl is_machikiflix_stack ssl_fc_sni -i sonarr.machiki.fr
    acl is_machikiflix_stack ssl_fc_sni -i radarr.machiki.fr
    acl is_machikiflix_stack ssl_fc_sni -i prowlarr.machiki.fr
    acl is_machikiflix_stack ssl_fc_sni -i bazarr.machiki.fr
    acl is_machikiflix_stack ssl_fc_sni -i qbittorrent.machiki.fr
    acl is_machikiflix_stack ssl_fc_sni -i pinchflat.machiki.fr

    default_backend machikiflix_backend

backend proxmox_backend
    mode http
    server proxmox proxmox.guerande.local.net:8006 check

backend machikiflix_backend
    mode http
    server machikiflix machikiflix.guerande.local.net:80 check
